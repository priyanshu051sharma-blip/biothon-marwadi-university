# Application
NODE_ENV=production
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://healthai:password@localhost:5432/healthai
MONGODB_URI=mongodb://localhost:27017/healthai
REDIS_URL=redis://localhost:6379

# TigerGraph
TIGERGRAPH_HOST=https://your-instance.i.tgcloud.io
TIGERGRAPH_USERNAME=tigergraph
TIGERGRAPH_PASSWORD=your_password
TIGERGRAPH_GRAPH_NAME=HealthGraph
TIGERGRAPH_SECRET=your_secret

# AI Services
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# AWS (Optional - for file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=healthai-storage
AWS_REGION=us-east-1

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@healthai.com

# Monitoring (Optional)
SENTRY_DSN=your-sentry-dsn
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_ML_MODELS=true
ENABLE_GRAPHRAG=true
ENABLE_NOTIFICATIONS=true
ENABLE_ANALYTICS=true
